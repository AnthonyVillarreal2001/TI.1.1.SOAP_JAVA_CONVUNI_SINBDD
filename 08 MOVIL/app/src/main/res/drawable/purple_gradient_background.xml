<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <bitmap
            android:src="@drawable/sulley"
            android:gravity="fill" />
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#6608111F"
                android:centerColor="#4408111F"
                android:endColor="#7708111F"
                android:type="linear" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#224F46E5"
                android:endColor="#005F9E0B"
                android:type="linear" />
        </shape>
    </item>

</layer-list>
